# SPEC §"Fixed Binding Reassignment" — must be rejected.
#
# `=!` creates an immutable binding; reassigning is illegal.

struct User
  name: String

fun loadUser(id: U64) -> User!
  User(name: "Steve")

fun refreshUser(id: U64) -> User!
  User(name: "Steve")

sub main()
  user =! loadUser(1)!
  user = refreshUser(1)!
