# M18: match-as-expression with multi-statement arm bodies. Each
# arm's body block lowers to `pattern => rig_blk_N: { ...; break
# :rig_blk_N <expr>; }`. Single-expression arms still emit inline.
enum Op
  add
  minus

fun apply(op: Op, a: Int, b: Int) -> Int
  match op
    .add
      tmp = a + b
      tmp
    .minus
      tmp = a - b
      tmp

sub main()
  print(apply(.add, 3, 4))
  print(apply(.minus, 10, 3))
