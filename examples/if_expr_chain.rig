# M17: `if`/`else if`/`else` chains nest cleanly because each
# `else` branch is itself a single-statement block whose only
# statement is another if-expression, which the emitter inlines.
fun classify(x: Int) -> Int
  if x > 0
    1
  else
    if x < 0
      -1
    else
      0

sub main()
  print(classify(5))
  print(classify(-5))
  print(classify(0))
