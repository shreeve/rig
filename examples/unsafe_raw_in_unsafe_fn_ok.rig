## M19(2/6): raw `%x` access inside an `unsafe` fn body is allowed.
##
## Per GPT-5.5 entry 35 + 36 (M19 design): the entire body of an
## unsafe fn (declared with prefix `unsafe sub` or `unsafe fun`)
## is treated as an unsafe context, Rust-style. No need for a
## redundant `unsafe` block inside an `unsafe` fn. The function's
## external contract is "calling this is unsafe"; the internal
## body just operates in that mode by default.

unsafe sub raw_op(x: Int)
  r = %x           # OK: body of unsafe fn is unsafe context
  print(r)

sub main()
  unsafe
    raw_op(42)     # caller wraps; M19(4/6) enforces this rigorously
