# M20h(5/5): owned-closure invocation arity must match.
#
# A `*Closure()` is the no-arg form and rejects any call args.
# Arity-bearing variants `*Closure1(T)` and `*Closure2(A, B)`
# shipped in M24 — but here the binding is the no-arg `*Closure()`,
# so calling with two args is an arity mismatch.

sub main()
  count: *Cell(Int) = *Cell(value: 0)
  cb: *Closure() = *Closure(|+count| count.set(count.get() + 1))
  cb(1, 2)
