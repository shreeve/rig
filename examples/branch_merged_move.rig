## M4.5b: if EITHER branch moves, post-if use is invalid (merge).
##
## After the if, `x` may or may not have been moved depending on
## runtime cond. Conservative merge says: dropped > moved > valid,
## so post-if `print x` must error.

fun make() -> Int
  42

sub send(v: Int)
  print(v)

sub main()
  cond = true
  x = make()
  if cond
    send <x
  else
    print x
  print x
