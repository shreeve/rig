# Spacing-sensitive sigil classification (per GPT-5.5 review).
#
# These pairs MUST tokenize differently:
#
#   <x   move prefix      vs    a < x   less-than infix
#   *x   share prefix     vs    a * b   multiply infix
#   +x   clone prefix     vs    a + b   plus infix
#   %x   raw prefix       vs    a % b   modulo infix
#   ?x   read prefix      vs    expr?   propagate (postfix)
#   @x   pin prefix       vs    @len(x) builtin call (pin RESERVED in V1)
#   a.*  deref            vs    *x      share prefix
#   y = -x  expr negation vs    -x      drop statement (at stmt-start)

sub main()
  a = 1
  b = 2
  c = a < x          # infix: (< a x)
  d = a * b          # infix: (* a b)
  e = a + b          # infix: (+ a b)
  f = a % b          # infix: (% a b)
  g = @len(arr)      # builtin: (builtin len arr)
  h = a.*            # deref: (deref a)
  m = <x             # move: (move x)
  s = *x             # share: (share x)
  k = +x             # clone: (clone x)
  # M22: `%x` raw access requires a `raw` block. The
  # tokenization test still applies (this file's purpose is
  # sigil classification); wrap in `raw` so the example
  # passes the M22 effects check while preserving the
  # raw-prefix tokenization signal.
  raw
    r = %x           # raw: (raw x)
  # M22.1: `@x` lexer still tokenizes as pin_pfx (preserved so the
  # disambiguation from `@len(x)` keeps working), but sema rejects
  # the resulting `(pin x)` IR — pinning is reserved for V2. The
  # line stays so the tokenization signal is exercised; the sema
  # error becomes part of the spacing.rig errors-golden.
  p = @x             # pin: (pin x)  (errors: V1 rejects pin)
  rb = ?x            # read borrow: (read x)
  wb = !x            # write borrow: (write x)
  y = -x             # negation in expr position: (neg x)

  # Drop is only at statement-start (per SPEC: "Drop is statement-only")
  -y                 # drop: (drop y)

  # Multi-pair constructor:
  u = User(name: "Steve", age: 42)

  # Mixed positional + named (named must come last for sanity, but parser
  # tolerates any order in V1).
  v = make(arena, name: "Steve")
