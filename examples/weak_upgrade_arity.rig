# M20d.2 (negative): `w.upgrade()` is a built-in method on weak
# handles; it takes no arguments. Passing any args fires a targeted
# diagnostic. Pinned because the M20d.1 intercept's arity check
# predates the M20d.2 formalization-as-built-in; this golden ensures
# the message survives future refactors.

struct User
  name: String

sub main()
  rc = *User(name: "x")
  w  = ~rc
  m  = w.upgrade(42)
  -rc
  -w
