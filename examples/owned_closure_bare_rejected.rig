# M20h(5/5): bare `Closure(fn ...)` (no `*`) is rejected.
#
# Owned-closure construction MUST be wrapped with `*` so the
# heap allocation is visible at the construction site. Without
# the `*`, the user has a malformed constructor call (Closure
# takes zero type args, the lambda is being supplied as if it
# were a type), and sema fires a tailored hint.

sub main()
  count: *Cell(Int) = *Cell(value: 0)
  cb = Closure(fn |+count| count.set(count.get() + 1))
