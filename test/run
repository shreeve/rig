#!/bin/bash
# Rig test runner.
#
# Runs:
#   1. Golden raw_sexp tests — parse each example, byte-diff against snapshot
#   2. Compile checks — verify generated parser.zig compiles
#   3. Determinism — same input, two runs, identical output
#   4. zig build test — Zig-native unit tests in src/rig.zig
#
# Usage:
#   ./test/run            run all tests
#   ./test/run --update   regenerate goldens (review diffs before committing)

set -euo pipefail

cd "$(dirname "$0")/.."

RIG=bin/rig
TMPDIR=$(mktemp -d)
trap "rm -rf $TMPDIR" EXIT

UPDATE=false
if [[ "${1:-}" == "--update" ]]; then
    UPDATE=true
fi

if [[ ! -x "$RIG" ]]; then
    echo "Building rig..."
    zig build
fi

if [[ -t 1 && -z "${NO_COLOR:-}" ]]; then
    C_GREEN=$'\033[32m'
    C_RED=$'\033[31m'
    C_YELLOW=$'\033[33m'
    C_DIM=$'\033[2m'
    C_BOLD=$'\033[1m'
    C_RESET=$'\033[0m'
else
    C_GREEN='' C_RED='' C_YELLOW='' C_DIM='' C_BOLD='' C_RESET=''
fi

PASS=0
FAIL=0
ERRORS=""

say_pass()   { printf "  %sPASS%s  %s\n"   "$C_GREEN"  "$C_RESET" "$*"; }
say_fail()   { printf "  %sFAIL%s  %s\n"   "$C_RED"    "$C_RESET" "$*"; }
say_update() { printf "  %sUPDATE%s  %s\n" "$C_GREEN"  "$C_RESET" "$*"; }
section()    { printf "%s=== %s ===%s\n\n" "$C_BOLD" "$*" "$C_RESET"; }
section_done() { local e=$1; (( e > 0 )) && printf "  %s(%ds)%s\n\n" "$C_DIM" "$e" "$C_RESET" || printf "\n"; }

SUITE_START=$SECONDS

# -----------------------------------------------------------------------------
# 1. Golden Sexp tests (raw + semantic)
# -----------------------------------------------------------------------------

run_golden() {
    local rig_file=$1
    local subcmd=$2          # parse | normalize
    local kind=$3            # raw_sexp | semantic_sexp
    local name=$(basename "$rig_file" .rig)
    local golden="test/golden/${kind}/${name}.sexp"
    local out="$TMPDIR/${kind}_${name}.sexp"

    if ! $RIG "$subcmd" "$rig_file" > "$out" 2>&1; then
        FAIL=$((FAIL + 1))
        ERRORS+=$'\n'"  ${C_RED}FAIL${C_RESET}  ${kind}/$name — $subcmd failed: $(cat "$out")"
        return
    fi

    if $UPDATE; then
        mkdir -p "$(dirname "$golden")"
        cp "$out" "$golden"
        say_update "${kind}/$name"
        PASS=$((PASS + 1))
        return
    fi

    if [[ ! -f "$golden" ]]; then
        FAIL=$((FAIL + 1))
        ERRORS+=$'\n'"  ${C_RED}FAIL${C_RESET}  ${kind}/$name — no golden (run with --update)"
        return
    fi

    if diff -q "$golden" "$out" >/dev/null 2>&1; then
        say_pass "${kind}/$name"
        PASS=$((PASS + 1))
    else
        FAIL=$((FAIL + 1))
        local lines=$(diff "$golden" "$out" | grep -c '^[<>]' || true)
        ERRORS+=$'\n'"  ${C_RED}FAIL${C_RESET}  ${kind}/$name — $lines lines differ"
    fi
}

section "Golden raw_sexp"
SECTION_START=$SECONDS
for f in examples/*.rig; do
    [[ -e "$f" ]] || continue
    run_golden "$f" parse raw_sexp
done
section_done $(( SECONDS - SECTION_START ))

section "Golden semantic_sexp"
SECTION_START=$SECONDS
for f in examples/*.rig; do
    [[ -e "$f" ]] || continue
    run_golden "$f" normalize semantic_sexp
done
section_done $(( SECONDS - SECTION_START ))

# -----------------------------------------------------------------------------
# 1c. Golden ownership errors
# -----------------------------------------------------------------------------

run_golden_errors() {
    local rig_file=$1
    local name=$(basename "$rig_file" .rig)
    local golden="test/golden/errors/${name}.txt"
    local out="$TMPDIR/errors_${name}.txt"

    # `rig check` exits 1 when there are errors; capture both ways.
    $RIG check "$rig_file" > "$out" 2>&1 || true

    if $UPDATE; then
        mkdir -p "$(dirname "$golden")"
        cp "$out" "$golden"
        say_update "errors/$name"
        PASS=$((PASS + 1))
        return
    fi

    if [[ ! -f "$golden" ]]; then
        FAIL=$((FAIL + 1))
        ERRORS+=$'\n'"  ${C_RED}FAIL${C_RESET}  errors/$name — no golden (run with --update)"
        return
    fi

    if diff -q "$golden" "$out" >/dev/null 2>&1; then
        say_pass "errors/$name"
        PASS=$((PASS + 1))
    else
        FAIL=$((FAIL + 1))
        local lines=$(diff "$golden" "$out" | grep -c '^[<>]' || true)
        ERRORS+=$'\n'"  ${C_RED}FAIL${C_RESET}  errors/$name — $lines lines differ"
    fi
}

section "Golden errors"
SECTION_START=$SECONDS
for f in examples/*.rig; do
    [[ -e "$f" ]] || continue
    run_golden_errors "$f"
done
section_done $(( SECONDS - SECTION_START ))

# -----------------------------------------------------------------------------
# 1d. Golden emitted Zig (only for examples that pass the checker cleanly)
# -----------------------------------------------------------------------------

EMIT_TARGETS=(hello shadow struct_basic enum_basic enum_valued match_basic match_default payload_enum match_destructure match_value_position qualified_enum struct_method match_range generic_box generic_pair if_expr_basic if_expr_chain if_expr_block if_expr_binding if_expr_early_return if_expr_enum_variant match_expr_block match_expr_binding match_expr_mixed match_expr_early_return typed_counter typed_accumulator method_self_read method_self_write method_self_consume method_associated_return method_enum method_two_self_methods)

run_golden_emit() {
    local name=$1
    local rig_file="examples/${name}.rig"
    local golden="test/golden/emitted_zig/${name}.zig"
    local out="$TMPDIR/emit_${name}.zig"

    if ! $RIG build "$rig_file" > "$out" 2>&1; then
        FAIL=$((FAIL + 1))
        ERRORS+=$'\n'"  ${C_RED}FAIL${C_RESET}  emit/$name — build failed"
        return
    fi

    if $UPDATE; then
        mkdir -p "$(dirname "$golden")"
        cp "$out" "$golden"
        say_update "emit/$name"
        PASS=$((PASS + 1))
        return
    fi

    if [[ ! -f "$golden" ]]; then
        FAIL=$((FAIL + 1))
        ERRORS+=$'\n'"  ${C_RED}FAIL${C_RESET}  emit/$name — no golden (run with --update)"
        return
    fi

    if diff -q "$golden" "$out" >/dev/null 2>&1; then
        say_pass "emit/$name"
        PASS=$((PASS + 1))
    else
        FAIL=$((FAIL + 1))
        local lines=$(diff "$golden" "$out" | grep -c '^[<>]' || true)
        ERRORS+=$'\n'"  ${C_RED}FAIL${C_RESET}  emit/$name — $lines lines differ"
    fi
}

run_emit_compile_check() {
    local name=$1
    local rig_file="examples/${name}.rig"
    local out="$TMPDIR/compile_${name}.zig"
    $RIG build "$rig_file" > "$out" 2>&1 || true
    if zig ast-check "$out" >/dev/null 2>&1; then
        say_pass "emit-compiles/$name"
        PASS=$((PASS + 1))
    else
        FAIL=$((FAIL + 1))
        ERRORS+=$'\n'"  ${C_RED}FAIL${C_RESET}  emit-compiles/$name — emitted Zig fails ast-check"
    fi
}

section "Golden emitted_zig"
SECTION_START=$SECONDS
for name in "${EMIT_TARGETS[@]}"; do
    run_golden_emit "$name"
done
section_done $(( SECONDS - SECTION_START ))

section "Emitted Zig compiles"
SECTION_START=$SECONDS
for name in "${EMIT_TARGETS[@]}"; do
    run_emit_compile_check "$name"
done
section_done $(( SECONDS - SECTION_START ))

# -----------------------------------------------------------------------------
# 1e. End-to-end run check
# -----------------------------------------------------------------------------

section "End-to-end run"
SECTION_START=$SECONDS
HELLO_OUT=$($RIG run examples/hello.rig 2>&1 || true)
if echo "$HELLO_OUT" | grep -q "hello, rig"; then
    say_pass "hello.rig runs and prints expected output"
    PASS=$((PASS + 1))
else
    FAIL=$((FAIL + 1))
    ERRORS+=$'\n'"  ${C_RED}FAIL${C_RESET}  hello.rig run — got: $HELLO_OUT"
fi
section_done $(( SECONDS - SECTION_START ))

# -----------------------------------------------------------------------------
# 1f. Multi-file module tests (M15)
# -----------------------------------------------------------------------------
#
# Each subdir of test/modules/ is a self-contained multi-file project.
# Convention: `main.rig` (or `a.rig` for cycle tests) is the entry
# point. If `expected.txt` exists, the test runs the project and
# compares output. If `expected_error.txt` exists, the test expects
# `rig run` to fail and the error output to contain the file's text.

run_module_project() {
    local dir=$1
    local name=$(basename "$dir")
    local entry="$dir/main.rig"
    [[ -f "$entry" ]] || entry="$dir/a.rig"
    [[ -f "$entry" ]] || { say_fail "modules/$name (no entry main.rig or a.rig)"; FAIL=$((FAIL + 1)); return; }

    local out="$TMPDIR/mod_${name}.out"
    set +e
    $RIG run "$entry" > "$out" 2>&1
    local exit=$?
    set -e

    if [[ -f "$dir/expected.txt" ]]; then
        local want=$(cat "$dir/expected.txt")
        if [[ $exit -eq 0 ]] && grep -qF "$want" "$out"; then
            say_pass "modules/$name"
            PASS=$((PASS + 1))
        else
            FAIL=$((FAIL + 1))
            ERRORS+=$'\n'"  ${C_RED}FAIL${C_RESET}  modules/$name — exit=$exit, expected output containing \"$want\":"$'\n'"$(sed 's/^/    /' "$out")"
        fi
    elif [[ -f "$dir/expected_error.txt" ]]; then
        local want=$(cat "$dir/expected_error.txt")
        if [[ $exit -ne 0 ]] && grep -qF "$want" "$out"; then
            say_pass "modules/$name (expected error)"
            PASS=$((PASS + 1))
        else
            FAIL=$((FAIL + 1))
            ERRORS+=$'\n'"  ${C_RED}FAIL${C_RESET}  modules/$name — expected error containing \"$want\", got exit=$exit:"$'\n'"$(sed 's/^/    /' "$out")"
        fi
    else
        say_fail "modules/$name (no expected.txt or expected_error.txt)"
        FAIL=$((FAIL + 1))
    fi
}

if [[ -d test/modules ]]; then
    section "Multi-file modules"
    SECTION_START=$SECONDS
    for d in test/modules/*/; do
        [[ -d "$d" ]] || continue
        run_module_project "$d"
    done
    section_done $(( SECONDS - SECTION_START ))
fi

# -----------------------------------------------------------------------------
# 1g. Torture corpus (M16) — bad inputs must produce diagnostics, never crash
# -----------------------------------------------------------------------------
#
# Universal contract for every test/torture/*.rig:
#   1. `rig run` exits non-zero (bad input → clean rejection).
#   2. stderr is non-empty (some kind of diagnostic).
#   3. stderr NEVER contains panic phrases (segfault, panic, reached
#      unreachable, index out of bounds, general protection).
#
# Any panic phrase = compiler robustness regression = test failure.

PANIC_RE='Segmentation fault|panic:|panic at|reached unreachable|index out of bounds|general protection|GENERAL PROTECTION'

run_torture() {
    local rig_file=$1
    local name=$(basename "$rig_file" .rig)
    local out="$TMPDIR/torture_${name}.out"

    set +e
    timeout 10 $RIG run "$rig_file" > "$out" 2>&1
    local exit=$?
    set -e

    if grep -qE "$PANIC_RE" "$out"; then
        FAIL=$((FAIL + 1))
        ERRORS+=$'\n'"  ${C_RED}FAIL${C_RESET}  torture/$name — COMPILER PANIC on bad input (rc=$exit):"$'\n'"$(sed 's/^/    /' "$out" | head -8)"
        return
    fi

    if [[ $exit -eq 124 ]]; then
        FAIL=$((FAIL + 1))
        ERRORS+=$'\n'"  ${C_RED}FAIL${C_RESET}  torture/$name — timed out (likely infinite loop on bad input)"
        return
    fi

    if [[ $exit -eq 0 ]]; then
        FAIL=$((FAIL + 1))
        ERRORS+=$'\n'"  ${C_RED}FAIL${C_RESET}  torture/$name — bad input compiled+ran successfully (rc=0); did the language accept this?"
        return
    fi

    if [[ ! -s "$out" ]]; then
        FAIL=$((FAIL + 1))
        ERRORS+=$'\n'"  ${C_RED}FAIL${C_RESET}  torture/$name — exited rc=$exit but printed no diagnostic"
        return
    fi

    say_pass "torture/$name (rc=$exit, diagnostic ok)"
    PASS=$((PASS + 1))
}

if [[ -d test/torture ]]; then
    section "Torture corpus (must not panic)"
    SECTION_START=$SECONDS
    for f in test/torture/*.rig; do
        [[ -e "$f" ]] || continue
        run_torture "$f"
    done
    section_done $(( SECONDS - SECTION_START ))
fi

# -----------------------------------------------------------------------------
# 2. Compile check — generated parser.zig is syntactically valid Zig
# -----------------------------------------------------------------------------

section "Compile checks"
SECTION_START=$SECONDS
if zig ast-check src/parser.zig >/dev/null 2>&1; then
    say_pass "src/parser.zig (valid zig)"
    PASS=$((PASS + 1))
else
    say_fail "src/parser.zig (zig ast-check failed)"
    FAIL=$((FAIL + 1))
fi
section_done $(( SECONDS - SECTION_START ))

# -----------------------------------------------------------------------------
# 3. Determinism — same input, two runs, identical output
# -----------------------------------------------------------------------------

run_determinism() {
    local rig_file=$1
    local name=$(basename "$rig_file" .rig)
    local a="$TMPDIR/${name}_a.sexp"
    local b="$TMPDIR/${name}_b.sexp"
    $RIG parse "$rig_file" > "$a" 2>&1 || true
    $RIG parse "$rig_file" > "$b" 2>&1 || true
    if diff -q "$a" "$b" >/dev/null 2>&1; then
        say_pass "$name (deterministic)"
        PASS=$((PASS + 1))
    else
        FAIL=$((FAIL + 1))
        ERRORS+=$'\n'"  ${C_RED}FAIL${C_RESET}  $name — nondeterministic"
    fi
}

section "Determinism"
SECTION_START=$SECONDS
for f in examples/*.rig; do
    [[ -e "$f" ]] || continue
    run_determinism "$f"
done
section_done $(( SECONDS - SECTION_START ))

# -----------------------------------------------------------------------------
# 4. zig build test — unit tests in src/rig.zig
# -----------------------------------------------------------------------------

section "Zig unit tests"
SECTION_START=$SECONDS
if zig build test 2>&1 | tee "$TMPDIR/zig_test_log" >/dev/null; then
    say_pass "src/rig.zig (zig build test)"
    PASS=$((PASS + 1))
else
    say_fail "src/rig.zig (zig build test)"
    FAIL=$((FAIL + 1))
    ERRORS+=$'\n'"  $(cat "$TMPDIR/zig_test_log")"
fi
section_done $(( SECONDS - SECTION_START ))

# -----------------------------------------------------------------------------
# Summary
# -----------------------------------------------------------------------------

SUITE_ELAPSED=$(( SECONDS - SUITE_START ))
section "Results"
if (( FAIL == 0 )); then
    printf "  %s%d passed%s, %d failed  %s(total %ds)%s\n\n" \
        "$C_GREEN" "$PASS" "$C_RESET" "$FAIL" "$C_DIM" "$SUITE_ELAPSED" "$C_RESET"
else
    printf "  %d passed, %s%d failed%s  %s(total %ds)%s\n" \
        "$PASS" "$C_RED" "$FAIL" "$C_RESET" "$C_DIM" "$SUITE_ELAPSED" "$C_RESET"
    printf "%b\n\n" "$ERRORS"
    exit 1
fi
