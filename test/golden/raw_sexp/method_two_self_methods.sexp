(module (struct User (: name String) (fun greet ((read self)) String (block (member self name)))) (enum Color red green blue (fun code ((read self)) Int (block (match self (arm (enum_lit red) _ 1) (arm (enum_lit green) _ 2) (arm (enum_lit blue) _ 3))))) (sub main () _ (block (set _ u _ (call User (kwarg name "Steve"))) (set _ c _ (member Color red)) (call print (call (member u greet))) (call print (call (member c code))))))
