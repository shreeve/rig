(module (generic_enum Result (T E) (variant ok ((: value T))) (variant err ((: reason E)))) (sub main () _ (block (set _ good (generic_inst Result Int String) (call (enum_lit ok) (kwarg value 42))) (set _ bad (generic_inst Result Int String) (call (enum_lit err) (kwarg reason "oops"))) (match good (arm (enum_lit ok) _ (call print "42")) (arm (enum_lit err) _ (call print "nope"))) (match bad (arm (enum_lit ok) _ (call print "nope")) (arm (enum_lit err) _ (call print "oops"))))))
