(module (sub main () _ (block (set a 1) (set b 2) (set c (< a x)) (set d (* a b)) (set e (+ a b)) (set f (% a b)) (set g (builtin len arr)) (set h (deref a)) (set m (move x)) (set s (share x)) (set k (clone x)) (set r (raw x)) (set p (pin x)) (set rb (read x)) (set wb (write x)) (set y (neg x)) (drop y) (set u (call User (kwarg name "Steve") (kwarg age 42))) (set v (call make arena (kwarg name "Steve"))))))
