(module (enum Sign pos neg zero) (fun classify ((: x Int)) Sign (block (if (> x 0) (block (enum_lit pos)) (block (if (< x 0) (block (enum_lit neg)) (block (enum_lit zero))))))) (fun to_int ((: s Sign)) Int (block (match s (arm (enum_lit pos) _ 1) (arm (enum_lit neg) _ (neg 1)) (arm (enum_lit zero) _ 0)))) (sub main () _ (block (call print (call to_int (call classify 5))) (call print (call to_int (call classify (neg 3)))) (call print (call to_int (call classify 0))))))
