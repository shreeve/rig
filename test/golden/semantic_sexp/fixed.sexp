(module (fun loadUser ((: id U64)) (error_union User) (block (call User (kwarg name "Steve")))) (fun refreshUser ((: id U64)) (error_union User) (block (call User (kwarg name "Steve")))) (sub main () _ (block (fixed_bind user _ (propagate (call loadUser 1))) (set user _ (propagate (call refreshUser 1))))))
