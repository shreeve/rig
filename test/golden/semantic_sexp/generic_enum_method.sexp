(module (generic_enum Option (T) (variant some ((: value T))) none (fun is_some ((read self)) Bool (block (match self (arm (enum_lit some) _ true) (arm (enum_lit none) _ false))))) (sub main () _ (block (set _ o1 (generic_inst Option Int) (call (enum_lit some) (kwarg value 1))) (set _ o2 (generic_inst Option Int) (enum_lit none)) (call print (call (member o1 is_some))) (call print (call (member o2 is_some))))))
