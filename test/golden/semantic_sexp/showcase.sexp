(module (struct User (: name String) (: id U64)) (struct Profile (: name String)) (struct UserView (: user (borrow_read User)) (: profile (borrow_read Profile))) (enum ParseMode strict loose) (struct Ast (: ok Bool)) (struct Bytes (: data Int)) (fun parseStrict ((: input (borrow_read Bytes))) Ast (block (call Ast (kwarg ok true)))) (fun parseLoose ((: input (borrow_read Bytes))) Ast (block (call Ast (kwarg ok false)))) (fun add ((: a Int) (: b Int)) Int (block (+ a b))) (fun loadUser ((: id U64)) (error_union User) (block (call User (kwarg name "Steve") (kwarg id id)))) (fun loadProfile ((: id U64)) (error_union Profile) (block (call Profile (kwarg name "Steve")))) (fun parse ((pre_param mode ParseMode) (: input (borrow_read Bytes))) Ast (block (if (== mode (enum_lit strict)) (block (call parseStrict (read input))) (block (call parseLoose (read input)))))) (generic_type Box (T) (: value T)) (sub main () _ (block (set _ total _ (call add 1 2)) (call print total) (set fixed user _ (propagate (call loadUser 1))) (call print (read user)) (set move other _ user) (set _ u _ (propagate (call loadUser 1))) (set _ p _ (propagate (call loadProfile (member u id)))) (set _ view _ (call UserView (kwarg user (read u)) (kwarg profile (read p)))) (drop other))))
